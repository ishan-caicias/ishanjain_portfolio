---
import RoverAnimation from "@/components/islands/RoverAnimation";
import MercurySurfaceFooter from "@/components/layout/MercurySurfaceFooter.astro";
---

<footer
  id="site-footer"
  class="relative mt-24 overflow-hidden"
  role="contentinfo"
  data-testid="site-footer"
>
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-4 px-6 pt-8 pb-4">
    <p class="text-center text-sm text-pine-400/60">
      Built with Astro, React, and a love for the cosmos.
      <br />
      &copy; {new Date().getFullYear()} Ishan Jain. All rights reserved.
      <br />
      <a href="/credits" class="text-blue-400 underline hover:text-blue-300">Image Credits</a>
    </p>
    <div
      class="footer-rover-layer pointer-events-none flex w-full max-w-[1440px] items-end justify-center"
      style="height: var(--mercury-footer-height);"
      aria-hidden="true"
    >
      <div class="pointer-events-auto relative h-full w-full">
        <RoverAnimation client:idle />
      </div>
    </div>
  </div>
  <MercurySurfaceFooter />
</footer>

<style is:global>
  @media (max-width: 640px) {
    .footer-rover-layer {
      height: var(--mercury-footer-height-sm) !important;
    }
  }
</style>
