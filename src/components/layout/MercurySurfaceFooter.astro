---
/**
 * MercurySurfaceFooter – fixed bottom band, decorative only.
 * Tweak height: --mercury-footer-height / --mercury-footer-height-sm in global.css.
 * Tweak colors: .mercury-base and .mercury-crater use theme/site grays and browns.
 * Craters: add/remove <div class="mercury-crater" style="..." /> or adjust --crater-size.
 */
---
<div
  data-testid="mercury-footer"
  class="mercury-surface-footer relative left-0 right-0 w-full pointer-events-none select-none"
  style="
    height: var(--mercury-footer-height);
  "
  aria-hidden="true"
>
  <!-- Base regolith: gradients (no images) -->
  <div
    class="mercury-base absolute inset-0 w-full"
    style="
      background:
        linear-gradient(180deg,
          #1a1816 0%,
          #252220 25%,
          #2a2624 50%,
          #1e1c1a 75%,
          #161412 100%
        );
    "
  />
  <!-- SVG noise overlay (feTurbulence) for rocky texture -->
  <svg class="absolute inset-0 h-full w-full opacity-40" aria-hidden="true">
    <defs>
      <filter id="mercury-noise" x="0" y="0">
        <feTurbulence
          type="fractalNoise"
          baseFrequency="0.04 0.08"
          numOctaves="3"
          result="noise"
        />
        <feColorMatrix in="noise" type="saturate" values="0" result="mono" />
        <feBlend in="SourceGraphic" in2="mono" mode="multiply" result="blended" />
      </filter>
    </defs>
    <rect width="100%" height="100%" fill="#252220" filter="url(#mercury-noise)" />
  </svg>
  <!-- Subtle craters (radial gradients) -->
  <div
    class="mercury-crater absolute rounded-full opacity-60"
    style="
      --crater-size: 80px;
      width: var(--crater-size);
      height: var(--crater-size);
      left: 12%;
      bottom: 15%;
      background: radial-gradient(
        circle at 40% 40%,
        #2a2624 0%,
        #1a1816 35%,
        #0f0e0c 70%
      );
    "
  />
  <div
    class="mercury-crater absolute rounded-full opacity-50"
    style="
      --crater-size: 50px;
      width: var(--crater-size);
      height: var(--crater-size);
      left: 38%;
      bottom: 25%;
      background: radial-gradient(
        circle at 35% 35%,
        #252220 0%,
        #161412 50%
      );
    "
  />
  <div
    class="mercury-crater absolute rounded-full opacity-55"
    style="
      --crater-size: 65px;
      width: var(--crater-size);
      height: var(--crater-size);
      right: 25%;
      bottom: 18%;
      background: radial-gradient(
        circle at 45% 45%,
        #2a2624 0%,
        #1e1c1a 40%,
        #12100e 75%
      );
    "
  />
  <div
    class="mercury-crater absolute rounded-full opacity-45"
    style="
      --crater-size: 40px;
      width: var(--crater-size);
      height: var(--crater-size);
      right: 12%;
      bottom: 30%;
      background: radial-gradient(
        circle at 40% 40%,
        #252220 0%,
        #161412 55%
      );
    "
  />
</div>

<style is:global>
  /* Responsive: slightly shorter on small screens */
  @media (max-width: 640px) {
    .mercury-surface-footer {
      height: var(--mercury-footer-height-sm) !important;
    }
  }
</style>
