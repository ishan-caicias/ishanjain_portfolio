---
interface Props {
  class?: string;
  hover?: boolean;
}

const { class: className = "", hover = true } = Astro.props;
---

<div
  class:list={[
    "rounded-xl border border-royal-700/30 bg-surface-card p-6",
    hover && "transition-all duration-300 hover:border-royal-500/50 hover:shadow-lg hover:shadow-royal-900/20",
    className,
  ]}
>
  <slot />
</div>
