---
interface Props {
  label: string;
  variant?: "default" | "gold" | "pine";
}

const { label, variant = "default" } = Astro.props;

const variantClasses = {
  default:
    "bg-royal-800/50 text-royal-200 border-royal-700/50",
  gold: "bg-gold-500/10 text-gold-400 border-gold-500/30",
  pine: "bg-pine-600/20 text-pine-400 border-pine-500/30",
};
---

<span
  class:list={[
    "inline-block rounded-full border px-3 py-1 text-xs font-medium",
    variantClasses[variant],
  ]}
>
  {label}
</span>
