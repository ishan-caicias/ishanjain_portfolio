---
import Starfield from "@/components/islands/Starfield";
import AstronautMascot from "@/components/islands/AstronautMascot";
import StarModal from "@/components/islands/StarModal";
---

<section
  id="hero"
  class="relative flex min-h-screen items-center justify-center overflow-hidden px-6"
  aria-label="Introduction"
>
  <!-- Starfield background -->
  <div class="absolute inset-0 -z-10">
    <Starfield client:load />
  </div>

  <!-- Astronaut (hidden on mobile) -->
  <div class="pointer-events-none absolute inset-0 hidden md:block">
    <AstronautMascot client:idle />
  </div>

  <!-- Star Modal (renders when star is clicked) -->
  <StarModal client:idle />

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-3xl text-center">
    <div
      class="mb-6 inline-flex items-center gap-2 rounded-full border border-royal-700/50 bg-surface-elevated/80 px-4 py-1.5 text-sm text-text-muted backdrop-blur-sm"
    >
      <span
        class="inline-block h-2 w-2 rounded-full bg-pine-500 animate-pulse"
        aria-hidden="true"></span>
      Sydney, AU
    </div>

    <h1
      class="font-heading text-4xl font-bold leading-tight text-text-primary md:text-6xl"
    >
      Building reliable systems
      <span class="block text-gold-400">that move money safely</span>
    </h1>

    <p
      class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-text-muted md:text-xl"
    >
      Backend-leaning full-stack engineer specialising in fintech risk
      infrastructure, microservices, and production ownership.
    </p>

    <div
      class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center"
    >
      <a
        href="#projects"
        class="inline-flex items-center gap-2 rounded-lg bg-royal-600 px-6 py-3 font-medium text-text-primary transition-all hover:bg-royal-500 hover:shadow-lg hover:shadow-royal-600/25"
      >
        View my work
        <svg
          class="h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M19 9l-7 7-7-7"></path>
        </svg>
      </a>
      <a
        href="#contact"
        class="inline-flex items-center gap-2 rounded-lg border border-royal-600 px-6 py-3 font-medium text-text-muted transition-all hover:border-gold-500/50 hover:text-gold-400"
      >
        Get in touch
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2" aria-hidden="true">
    <div
      class="flex h-8 w-5 items-start justify-center rounded-full border-2 border-royal-500/50 p-1"
    >
      <div class="h-2 w-1 animate-bounce rounded-full bg-royal-400"></div>
    </div>
  </div>
</section>
